# Art Agent — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── JWT Authentication (REQUIRED) ──────────────────────────────────────────────
# Generate a secret key with:
#   python -c "from secrets import token_urlsafe; print(token_urlsafe(32))"
JWT_SECRET_KEY=

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite default (MVP). Override for production PostgreSQL.
# Format: sqlite+aiosqlite:///./data/art.db
# For PostgreSQL: postgresql+asyncpg://user:pass@host:5432/art
DATABASE_URL=sqlite+aiosqlite:///./data/art.db

# ── Redis ───────────────────────────────────────────────────────────────────────
# Standard redis:// URL format.
# Format: redis://[:password@]host:port/db
# Leave empty to skip Redis-dependent features.
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider Selection ─────────────────────────────────────────────────────
# Options: glm, minimax, openai
LLM_PROVIDER=glm

# GLM (default)
GLM_API_KEY=
GLM_MODEL=glm-4.6-flash

# MiniMax (optional)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── WeChat Integration (optional) ──────────────────────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_AES_KEY=

# ── Server ──────────────────────────────────────────────────────────────────────
# Host and port inside the container (default: 0.0.0.0:8000)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
