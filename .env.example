# Art Agent — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── FIX B1: JWT ─────────────────────────────────────────────────────────────────
# Required. Generate with:
#   python -c "from secrets import token_urlsafe; print(token_urlsafe(32))"
JWT_SECRET_KEY=

# ── Database ────────────────────────────────────────────────────────────────────
# SQLite default (MVP). Override for production PostgreSQL.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/art

# ── Redis ───────────────────────────────────────────────────────────────────────
# Default: redis://localhost:6379/0
# For production with auth: redis://user:password@host:6379/0
# REDIS_URL=redis://localhost:6379/0

# ── LLM Providers ──────────────────────────────────────────────────────────────────────
# GLM (default)
GLM_API_KEY=
GLM_MODEL=glm-4.6-flash

# MiniMax (optional)
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── WeChat ──────────────────────────────────────────────────────────────────────
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=
WECHAT_AES_KEY=
